    <!-- Apply saved theme before paint to avoid a flash of the wrong mode -->
    <script>(function(){try{var t=localStorage.getItem("theme")||(window.matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light");document.documentElement.setAttribute("data-theme",t);}catch(e){}})();</script>
    <!-- Moda gallery -->
    <style>
        .moda-carousel {
            max-width: 640px;
            margin: 0 auto;            /* center the whole gallery */
            text-align: center;
            -webkit-tap-highlight-color: transparent;
        }
        /* 3D cover-flow deck */
        .moda-deck {
            position: relative;
            height: clamp(190px, 42vw, 280px);
            margin: 0 auto;
            perspective: 1300px;
            /* warm theme-colored spotlight behind the photos */
            background: radial-gradient(58% 74% at 50% 47%, rgba(255, 183, 3,.22), rgba(255, 183, 3,0) 72%);
        }
        .moda-card {
            position: absolute;
            top: 50%;
            left: 50%;
            width: clamp(210px, 54vw, 300px);
            aspect-ratio: 3 / 2;
            margin: 0;
            padding: 0;
            border: 0;
            border-radius: 14px;
            overflow: hidden;
            background: #0f1113;
            box-shadow: 0 20px 45px rgba(0, 0, 0, .4);
            transform: translate(-50%, -50%);
            transform-style: preserve-3d;
            transition: transform .48s cubic-bezier(.22, .68, .2, 1),
                        opacity .42s ease, filter .42s ease, box-shadow .4s ease;
            cursor: pointer;
            will-change: transform, opacity;
        }
        .moda-card.is-center {
            cursor: zoom-in;
            box-shadow: 0 26px 60px rgba(0, 0, 0, .45),
                        0 12px 46px rgba(255, 183, 3,.5),   /* warm glow */
                        0 0 0 2px rgba(255, 183, 3,.6);     /* accent ring */
        }
        /* subtle vignette to give every card depth */
        .moda-card::after {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 14px;
            pointer-events: none;
            box-shadow: inset 0 0 55px rgba(0, 0, 0, .38);
        }
        /* glossy light streak sweeping across the active photo */
        .moda-card.is-center::after {
            background: linear-gradient(115deg, transparent 38%, rgba(255, 255, 255, .32) 48%, rgba(255, 240, 200, .22) 52%, transparent 62%);
            background-size: 220% 100%;
            background-position: 145% 0;
            animation: modaShine 3.6s ease-in-out 0.5s infinite;
        }
        @keyframes modaShine {
            0%   { background-position: 145% 0; }
            42%  { background-position: -45% 0; }
            100% { background-position: -45% 0; }
        }
        /* ambient blurred fill so portrait + landscape both look good */
        .moda-card .moda-bg {
            position: absolute;
            inset: -10%;
            width: 120%;
            height: 120%;
            object-fit: cover;
            filter: blur(20px) brightness(.5) saturate(1.15);
        }
        .moda-card .moda-fg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        .moda-card.is-center .moda-fg { animation: modaKenBurns 4.5s ease-out both; }
        @keyframes modaKenBurns {
            from { transform: scale(1.05); }
            to   { transform: scale(1); }
        }
        /* arrows + play/pause */
        .moda-ctrl {
            position: absolute;
            z-index: 50;
            background: rgba(15, 17, 19, .5);
            color: #fff;
            border: 0;
            cursor: pointer;
            border-radius: 50%;
            line-height: 1;
            backdrop-filter: blur(4px);
            transition: background .2s ease, transform .2s ease;
        }
        .moda-ctrl:hover { background: rgba(255, 183, 3,.92); transform: translateY(-50%) scale(1.08); }
        .moda-arrow {
            top: 50%;
            transform: translateY(-50%);
            width: 42px; height: 42px;
            font-size: 24px;
        }
        .moda-prev { left: 0; }
        .moda-next { right: 0; }
        .moda-play {
            top: 12px; right: 12px;
            width: 34px; height: 34px;
            font-size: 13px;
            display: flex; align-items: center; justify-content: center;
        }
        .moda-play:hover { transform: scale(1.08); }
        /* editorial index counter */
        .moda-count {
            margin-top: 16px;
            font-size: .82rem;
            letter-spacing: .28em;
            color: #b6ada6;
            font-variant-numeric: tabular-nums;
        }
        .moda-count b { color: #ffb703; font-weight: 700; }
        /* centered thumbnail strip */
        .moda-thumbs {
            display: flex;
            justify-content: center;
            gap: 7px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .moda-thumb {
            flex: 0 0 auto;
            width: 52px;
            height: 40px;
            padding: 0;
            border: 2px solid transparent;
            border-radius: 7px;
            overflow: hidden;
            cursor: pointer;
            background: #eceff1;
            opacity: .55;
            transition: opacity .25s ease, border-color .25s ease, transform .25s ease;
        }
        .moda-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .moda-thumb:hover { opacity: 1; transform: translateY(-2px); }
        .moda-thumb.is-active { opacity: 1; border-color: #ffb703; transform: translateY(-2px); box-shadow: 0 4px 14px rgba(255, 183, 3,.55); }
        @media (max-width: 575px) {
            .moda-thumb { width: 42px; height: 32px; }
            .moda-arrow { width: 36px; height: 36px; font-size: 20px; }
        }
        @media (prefers-reduced-motion: reduce) {
            .moda-card { transition: opacity .4s ease; }
            .moda-card.is-center .moda-fg { animation: none; }
        }
        /* Lightbox */
        .moda-lightbox {
            position: fixed;
            inset: 0;
            z-index: 1080;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(17, 17, 17, .94);
            backdrop-filter: blur(4px);
            opacity: 0;
            transition: opacity .25s ease;
        }
        .moda-lightbox.is-open {
            display: flex;
            opacity: 1;
        }
        .moda-lb-figure {
            margin: 0;
            max-width: 90vw;
            max-height: 86vh;
        }
        .moda-lb-figure img {
            max-width: 90vw;
            max-height: 86vh;
            object-fit: contain;
            border-radius: 8px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, .55);
        }
        .moda-lb-close,
        .moda-lb-nav {
            position: absolute;
            background: rgba(255, 255, 255, .08);
            color: #fff;
            border: 0;
            cursor: pointer;
            border-radius: 50%;
            transition: background .2s ease;
            line-height: 1;
        }
        .moda-lb-close:hover,
        .moda-lb-nav:hover {
            background: rgba(255, 255, 255, .22);
        }
        .moda-lb-close {
            top: 22px;
            right: 26px;
            width: 46px;
            height: 46px;
            font-size: 30px;
        }
        .moda-lb-nav {
            top: 50%;
            transform: translateY(-50%);
            width: 54px;
            height: 54px;
            font-size: 34px;
        }
        .moda-lb-prev { left: 18px; }
        .moda-lb-next { right: 18px; }
        .moda-lb-counter {
            position: absolute;
            bottom: 22px;
            left: 0;
            right: 0;
            text-align: center;
            color: rgba(255, 255, 255, .75);
            font-size: .9rem;
            letter-spacing: .06em;
        }
        @media (max-width: 575px) {
            .moda-lb-nav { width: 44px; height: 44px; font-size: 28px; }
            .moda-lb-close { width: 40px; height: 40px; font-size: 26px; top: 14px; right: 14px; }
        }
    </style>
