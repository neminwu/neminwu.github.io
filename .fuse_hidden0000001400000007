            <button class="moda-lb-nav moda-lb-prev" id="modaLbPrev" aria-label="Previous">&#8249;</button>
            <figure class="moda-lb-figure"><img id="modaLbImg" src="" alt="Moda" /></figure>
            <button class="moda-lb-nav moda-lb-next" id="modaLbNext" aria-label="Next">&#8250;</button>
            <div class="moda-lb-counter" id="modaLbCounter"></div>
        </div>

    </div>

    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/js/bootstrap.bundle.min.js"></script>
    <!-- Core theme JS-->
    <script src="js/scripts.js?v=20260615g"></script>

    <script>
    // ── Moda: dynamic age + auto-playing carousel + lightbox ────────
    (function () {
        // Dynamic age from birthday 2024-03-30
        const ageEl = document.getElementById('moda-age');
        if (ageEl) {
            const born = new Date(2024, 2, 30); // month is 0-indexed
            const now = new Date();
            let age = now.getFullYear() - born.getFullYear();
            const m = now.getMonth() - born.getMonth();
            if (m < 0 || (m === 0 && now.getDate() < born.getDate())) age--;
            ageEl.textContent = age;
        }

        const stage = document.getElementById('modaStage');
        if (!stage) return;

        const PHOTOS = [
            'img/moda/web/moda_01.jpg', 'img/moda/web/moda_02.jpg',
            'img/moda/web/moda_03.jpg', 'img/moda/web/moda_04.jpg',
            'img/moda/web/moda_05.jpg', 'img/moda/web/moda_06.jpg',
            'img/moda/web/moda_07.jpg', 'img/moda/web/moda_08.jpg'
        ];
        const INTERVAL = 2800;

        const thumbsWrap = document.getElementById('modaThumbs');
        const playBtn = document.getElementById('modaPlay');
        const countEl = document.getElementById('modaCount');

        // Build cover-flow cards + thumbnails
        const cards = [];
        const thumbs = [];
        PHOTOS.forEach((src, i) => {
            const card = document.createElement('button');
            card.className = 'moda-card';
            card.type = 'button';
            card.setAttribute('aria-label', 'Photo ' + (i + 1) + ' of ' + PHOTOS.length);
            card.innerHTML =
                '<img class="moda-bg" src="' + src + '" alt="" aria-hidden="true" />' +
                '<img class="moda-fg" src="' + src + '" alt="Moda the cow cat" />';
            card.addEventListener('click', () => {
                if (i === index) lbOpen(index);   // center card -> fullscreen
                else go(i);                        // side card -> bring to front
            });
            stage.insertBefore(card, stage.firstChild);
            cards.push(card);

            const t = document.createElement('button');
            t.className = 'moda-thumb';
            t.type = 'button';
            t.setAttribute('aria-label', 'Show photo ' + (i + 1));
            t.innerHTML = '<img src="' + src + '" alt="" loading="lazy" />';
            t.addEventListener('click', () => { go(i); });
            thumbsWrap.appendChild(t);
            thumbs.push(t);
        });

        let index = 0, userPaused = false, hovering = false, timer = null;
        const n = cards.length;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        function effectivePlaying() { return !userPaused && !hovering; }

        // Position every card relative to the centered one (3D cover-flow)
        function layout() {
            cards.forEach((card, k) => {
                let off = k - index;
                if (off > n / 2) off -= n;
                if (off < -n / 2) off += n;
                const a = Math.abs(off), dir = Math.sign(off);
                let tx, tz, ry, sc, op, zi, br;
                if (a === 0)      { tx = 0;         tz = 0;    ry = 0;          sc = 1;   op = 1;   zi = 30; br = 1;   }
                else if (a === 1) { tx = dir * 50;  tz = -150; ry = -dir * 38;  sc = .66; op = .6;  zi = 20; br = .6;  }
                else if (a === 2) { tx = dir * 86;  tz = -320; ry = -dir * 44;  sc = .44; op = .24; zi = 10; br = .45; }
                else              { tx = dir * 108; tz = -400; ry = -dir * 46;  sc = .38; op = 0;   zi = 0;  br = .4;  }
                card.style.transform =
                    'translate(-50%, -50%) translateX(' + tx + '%) translateZ(' + tz + 'px) rotateY(' + ry + 'deg) scale(' + sc + ')';
                card.style.opacity = op;
                card.style.zIndex = zi;
                card.style.filter = 'brightness(' + br + ')';
                card.style.pointerEvents = op === 0 ? 'none' : 'auto';
                card.classList.toggle('is-center', a === 0);
            });
            thumbs.forEach((t, k) => t.classList.toggle('is-active', k === index));
            if (countEl) countEl.innerHTML = '<b>' + (index + 1) + '</b> / ' + n;
        }

        function setActive(i) { index = (i + n) % n; layout(); }
        function startAuto() {
            clearTimeout(timer);
            if (!effectivePlaying()) return;
            timer = setTimeout(() => go(index + 1), INTERVAL);
        }
        function stopAuto() { clearTimeout(timer); }
        function go(i) { setActive(i); startAuto(); }

        document.getElementById('modaPrev').addEventListener('click', () => go(index - 1));
        document.getElementById('modaNext').addEventListener('click', () => go(index + 1));
        playBtn.addEventListener('click', () => {
            userPaused = !userPaused;
            playBtn.innerHTML = userPaused ? '&#9654;' : '&#10073;&#10073;';
            playBtn.setAttribute('aria-label', userPaused ? 'Play slideshow' : 'Pause slideshow');
            if (userPaused) stopAuto(); else startAuto();
        });

        stage.addEventListener('mouseenter', () => { hovering = true; stopAuto(); });
        stage.addEventListener('mouseleave', () => { hovering = false; startAuto(); });

        // ---- Lightbox (full color) ----
        const lb = document.getElementById('modaLightbox');
        const lbImg = document.getElementById('modaLbImg');
        const counter = document.getElementById('modaLbCounter');
        let lbIdx = 0;
        function lbShow(i) {
            lbIdx = (i + PHOTOS.length) % PHOTOS.length;
            lbImg.setAttribute('src', PHOTOS[lbIdx]);
            counter.textContent = (lbIdx + 1) + ' / ' + PHOTOS.length;
        }
        function lbOpen(i) {
            lbShow(i);
            lb.classList.add('is-open');
            lb.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }
        function lbClose() {
            lb.classList.remove('is-open');
            lb.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }
        document.getElementById('modaLbClose').addEventListener('click', lbClose);
        document.getElementById('modaLbPrev').addEventListener('click', () => lbShow(lbIdx - 1));
        document.getElementById('modaLbNext').addEventListener('click', () => lbShow(lbIdx + 1));
        lb.addEventListener('click', (e) => { if (e.target === lb) lbClose(); });
        document.addEventListener('keydown', (e) => {
            if (!lb.classList.contains('is-open')) return;
            if (e.key === 'Escape') lbClose();
            else if (e.key === 'ArrowLeft') lbShow(lbIdx - 1);
            else if (e.key === 'ArrowRight') lbShow(lbIdx + 1);
        });

        // Init
        setActive(0);
        if (!reduce) startAuto();
        else { userPaused = true; playBtn.innerHTML = '&#9654;'; }
    })();
    </script>
