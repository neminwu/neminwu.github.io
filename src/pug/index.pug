doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='Nemin Wu — Ph.D. student in Geography and M.S. student in Artificial Intelligence at the University of Georgia.')
        meta(name='author', content='Nemin Wu')

        title Nemin Wu

        link(rel='icon', type='image/x-icon', href='img/nelephant.ico')

        // Font Awesome icons (free version)
        script(src='https://use.fontawesome.com/releases/v6.3.0/js/all.js', crossorigin='anonymous')

        // Core theme CSS (includes Bootstrap)
        link(href='css/styles.css?v=20260615j', rel='stylesheet')
        link(href='css/nav.css?v=20260615e', rel='stylesheet')

    body#page-top(data-page='index.html')

        // Navigation (generated from NAV config in scripts.js)
        nav#topNav.navbar.navbar-expand-lg.navbar-light.fixed-top
            #navInner.container-fluid.px-4

        // Page Content
        .main-content

            // About
            section#about.resume-section
                .resume-section-content
                    .d-flex.flex-column.flex-md-row.align-items-md-center.mb-4
                        img.img-profile.rounded-circle.me-md-4.mb-3.mb-md-0(src='img/neggplant.jpg', alt='Nemin Wu')
                        div
                            h1.mb-1 Nemin Wu
                            .subheading.mb-1 University of Georgia · Athens, GA
                            a(href='mailto:Nemin.Wu[at]uga.edu') Nemin.Wu[at]uga.edu
                    p.lead.mb-4.
                        Nemin Wu is a Ph.D. student in Geography and a Master's student in Artificial
                        Intelligence at the University of Georgia. She earned her Bachelor's degree from Wuhan University.
                        Her research is focused on spatial heterogeneity, spatial representation learning, and GIS for
                        health and environment. Nemin has been recognized with several awards, including 1st place in the
                        2024 AAG GISS Graduate Student Honors Paper Award, 1st place in the 2024 Graduate Student Lightning
                        Talk Competition on GIS Day at UGA, and 1st place for her presentation at the 10th Annual Health
                        Services Research Day at Emory University.
                    .social-icons
                        a.social-icon(href='https://www.linkedin.com/in/neminwu')
                            i.fab.fa-linkedin-in
                        a.social-icon(href='https://github.com/NeminWu')
                            i.fab.fa-github
                        a.social-icon(href='https://scholar.google.com/citations?hl=en&user=u2tvzX0AAAAJ')
                            i.fa-solid.fa-graduation-cap
                        a.social-icon.social-icon-img(href='https://www.researchgate.net/profile/Nemin-Wu', target='_blank')
                            img(src='img/researchgate.png', alt='ResearchGate')
                        a.social-icon.social-icon-img(href='https://orcid.org/0009-0001-7248-1144', target='_blank')
                            img(src='img/ORCID_iD.svg.png', alt='ORCID')

        // Bootstrap core JS
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/js/bootstrap.bundle.min.js')

        // Core theme JS
        script(src='js/scripts.js?v=20260615f')
